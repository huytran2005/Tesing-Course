        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "const isSuccess = pm.response.code === 200;\r",
                  "\r",
                  "/**\r",
                  " * [N] NORMAL - Luồng chuẩn (3 Cases)\r",
                  " */\r",
                  "pm.test(\"N1 - Authentication: Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"N2 - Token Harvest: Access token is a valid string\", () => {\r",
                  "    if (isSuccess) {\r",
                  "        pm.expect(res.access_token).to.be.a('string').and.not.empty;\r",
                  "        // Ghi điểm: Lưu staff_token vào môi trường\r",
                  "        pm.environment.set(\"staff_token\", res.access_token);\r",
                  "    } else {\r",
                  "        pm.expect.fail(\"Skipped: No token found in failed response\");\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"N3 - Payload Check: Response contains essential data\", () => {\r",
                  "    // Kiểm tra xem có dữ liệu đi kèm không (ví dụ: thông tin staff)\r",
                  "    pm.expect(res).to.be.an('object');\r",
                  "});\r",
                  "\r",
                  "/**\r",
                  " * [A] ABNORMAL - Luồng lỗi (1 Case)\r",
                  " */\r",
                  "pm.test(\"A1 - Defense: Content-Type is application/json\", () => {\r",
                  "    // Đảm bảo hệ thống luôn trả về JSON để script không bị \"gãy\"\r",
                  "    pm.response.to.be.json;\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "});\r",
                  "// B1 - Luu vao bien staff_token RIENG BIET\r",
                  "pm.test(\"B1 - Save Staff Token\", () => {\r",
                  "    if (data.access_token) {\r",
                  "        pm.environment.set(\"staff_token\", data.access_token);\r",
                  "        console.log(\"Da luu token moi cho Staff\");\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"staff@gmail.com\",\r\n  \"password\": \"123456\"\r\n}",
              "options": {
