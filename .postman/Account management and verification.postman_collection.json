        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "const isSuccess = pm.response.code === 200;\r",
                  "\r",
                  "/**\r",
                  " * [N] NORMAL - Luồng chuẩn (3 Cases)\r",
                  " * Tập trung vào việc xác thực và lưu trữ Token cho khách hàng\r",
                  " */\r",
                  "pm.test(\"N1 - Authorization: Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"N2 - Customer Token: Data is valid and saved\", () => {\r",
                  "    if (isSuccess) {\r",
                  "        pm.expect(res.access_token).to.be.a('string').and.not.empty;\r",
                  "        // Lưu token vào môi trường để dùng cho các API sau của khách\r",
                  "        pm.environment.set(\"customer_token\", res.access_token);\r",
                  "    } else {\r",
                  "        pm.test.skip(\"Skipped: Response failed, no token to save.\");\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"N3 - Response Content: JSON structure is correct\", () => {\r",
                  "    // Đảm bảo phản hồi trả về đúng đối tượng JSON\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "/**\r",
                  " * [A] ABNORMAL - Luồng lỗi (1 Case)\r",
                  " * Phòng ngự trước các trường hợp server trả về không đúng định dạng\r",
                  " */\r",
                  "pm.test(\"A1 - Security Defense: Headers are present\", () => {\r",
                  "    // Kiểm tra xem có Header Content-Type để tránh lỗi parse\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
