        {
          "name": "restaurants",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// [N1] Kiểm tra tạo nhà hàng thành công (Status 201)\r",
                  "pm.test(\"N1 - Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// [N2] Kiểm tra phản hồi trả về đúng định dạng JSON và có ID\r",
                  "let data = pm.response.json();\r",
                  "pm.test(\"N2 - Response is JSON and Restaurant created with ID\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "    pm.expect(data).to.have.property(\"id\");\r",
                  "    \r",
                  "    // Lưu ID vào môi trường để sử dụng cho các API sau\r",
                  "    pm.environment.set(\"restaurant_id\", data.id);\r",
                  "});\r",
                  "\r",
                  "// [B1] Kiểm tra định dạng dữ liệu trả về (Kiểu dữ liệu ID)\r",
                  "// Đây là Case Boundary để xác nhận ID trả về đúng định dạng chuỗi (UUID)\r",
                  "pm.test(\"B1 - Data types of ID is correct\", function () {\r",
                  "    pm.expect(data.id).to.be.a('string'); \r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
