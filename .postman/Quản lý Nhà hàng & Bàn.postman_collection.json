        {
          "name": "Update restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// [N1] Kiểm tra cập nhật ảnh thành công\r",
                  "pm.test(\"N1 - Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// [N2] Kiểm tra phản hồi trả về đúng định dạng JSON\r",
                  "pm.test(\"N2 - Response is JSON format\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "// [B1] Kiểm tra xem phản hồi có chứa đường dẫn ảnh (URL/Path) không\r",
                  "// Đây là Case Boundary (Biên) để xác nhận dữ liệu trả về có nội dung\r",
                  "let jsonData = pm.response.json();\r",
                  "pm.test(\"B1 - Response contains image URL or status\", function () {\r",
                  "    // Check xem có trường url hoặc image hoặc message không\r",
                  "    pm.expect(jsonData).to.be.an('object');\r",
                  "    pm.expect(Object.keys(jsonData).length).to.be.at.least(1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
