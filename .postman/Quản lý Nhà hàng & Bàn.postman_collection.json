        {
          "name": "Delete restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// [N1] Kiểm tra xóa nhà hàng thành công (Status 200 hoặc 204)\r",
                  "pm.test(\"N1 - Status code is 200 or 204\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);\r",
                  "});\r",
                  "\r",
                  "// [N2] Kiểm tra phản hồi trả về đúng định dạng JSON\r",
                  "pm.test(\"N2 - Response is JSON format\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "// [A1] Kiểm tra phản hồi xác nhận việc xóa (Abnormal/Verify)\r",
                  "// Đảm bảo Body trả về có chứa thông báo thành công hoặc không rỗng\r",
                  "let jsonData = pm.response.json();\r",
                  "pm.test(\"A1 - Delete operation is confirmed in response\", function () {\r",
                  "    pm.expect(jsonData).to.be.an('object');\r",
                  "    // Kiểm tra xem có message báo xóa thành công không\r",
                  "    pm.expect(jsonData).to.have.any.keys('message', 'status', 'id');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
