                  "});\r",
                  "\r",
                  "// [N2] Kiểm tra phản hồi trả về đúng định dạng JSON\r",
                  "pm.test(\"N2 - Response is JSON format\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "// [N3] Kiểm tra dữ liệu trả về phải là một danh sách (Array)\r",
                  "// Đảm bảo hệ thống trả về mảng dữ liệu ngay cả khi trống\r",
                  "let data = pm.response.json();\r",
                  "pm.test(\"N3 - Response data is an array\", function () {\r",
                  "    pm.expect(data).to.be.an(\"array\");\r",
                  "    pm.expect(data).to.not.be.null;\r",
                  "});"
